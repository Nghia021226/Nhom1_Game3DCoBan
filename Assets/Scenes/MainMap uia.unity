  bossVirtualCamera: {fileID: 761454309}
  dialoguePanel: {fileID: 2062097364}
  dialogueText: {fileID: 383903054}
  dialogueContent:
  - lineText: "\u1ED2"
    voiceClip: {fileID: 8300000, guid: c49acb2edb6a8044fb84c0ad1f718e79, type: 3}
  - lineText: "Ng\u01B0\u01A1i \u0111\xE3 \u0111\u1EBFn \u0111\u01B0\u1EE3c \u0111\xE2y
      r\u1ED3i sao ?"
    voiceClip: {fileID: 8300000, guid: e3158031da5d44b4cb5fef1fe8b924fe, type: 3}
  - lineText: "\xC0.....Ta c\u0169ng kh\xF4ng ng\u1EA1c nhi\xEAn cho l\u1EAFm"
    voiceClip: {fileID: 8300000, guid: 3506ecbdb862fa7418bda1cc67eac01a, type: 3}
  - lineText: "(\xC0 m\xE0 khoan \u0111\xE3....m\xECnh l\xE0...sinh v\u1EADt ngo\xE0i
      h\xE0nh tinh m\xE0 ta??? kh\xF4ng th\u1EC3 n\xE0o m\xE0....n\xF3i chuy\u1EC7n
      nh\u01B0 con ng\u01B0\u1EDDi \u0111\u01B0\u1EE3c...)"
    voiceClip: {fileID: 8300000, guid: 55fa07df354571542acce75b6ce4bf3b, type: 3}
  - lineText: ALQNFJAQEGNGELE!!!!!
    voiceClip: {fileID: 8300000, guid: 7e932b82e2214404eb757987c135adc2, type: 3}
  - lineText: ArrrrrrrrrUUUUUUUUrrrrrrrrAAAAAAA!!!!!!
    voiceClip: {fileID: 8300000, guid: 15b366dc7256c7c4792fb3e79e57d451, type: 3}
  - lineText: LELEELLELLUUULULEELE!!!!!
    voiceClip: {fileID: 8300000, guid: baf58b3d43f337e4e8c394aab7c8bc2b, type: 3}
  - lineText: LLLLLSSSSSSSSSS!!!!!!!!!!???????
    voiceClip: {fileID: 8300000, guid: 0a725995ce92b4c46a8d3a8854cd4005, type: 3}
  - lineText: ABUBU......!!!!!! ABEBE.....!!!!! ABUBU....!!!!!
    voiceClip: {fileID: 8300000, guid: 53ec15599a823e14fa025d58d5abf0db, type: 3}
  - lineText: MABE!!!!!!!
    voiceClip: {fileID: 8300000, guid: fd4b944183c911448843018bbd1166f1, type: 3}
  - lineText: WASOPESU!!!!!!!!!
    voiceClip: {fileID: 8300000, guid: f4683573ca887f84a90cad372cafc1f6, type: 3}
  skipButton: {fileID: 1144767304}
  audioSource: {fileID: 191503779}
